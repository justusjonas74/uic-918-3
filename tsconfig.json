{
    "compilerOptions": {
        "module": "commonjs",
        "esModuleInterop": true,
        "target": "es6",
        "outDir": "./built",
        "allowJs": true,
        "noEmitOnError": true,
        "moduleResolution": "node",
        "baseUrl": ".",
        "strict": true,
        "pretty":false,
        "paths": {
            "*": [
                "node_modules/*",
                "src/types/*"
            ]
        }
    },
    "include": [
        "./lib/**/*"
    ],
     "exclude": [
        "node_modules",
        "**/*Test.js"
    ]
}