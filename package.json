{
  "name": "uic-918-3",
  "version": "0.4.0",
  "description": "Package for decoding and parsing barcodes according to UIC-918.3 specification, which are used commonly on public transport online tickets.",
  "main": "lib/index.js",
  "scripts": {
    "tsc": "tsc",
    "test": "NODE_ENV=test nyc mocha",
    "coveralls": "nyc report --reporter=text-lcov | coveralls",
    "postinstall": "node ./lib/updateCerts.js"
  },
  "author": "Francis Doege",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^10.12.10",
    "iconv-lite": "^0.4.24",
    "jsrsasign": "^8.0.12",
    "lodash": "^4.17.11",
    "ot-aztec-extract": "git+https://github.com/pbock/ot-aztec-extract.git",
    "request": "^2.88.0",
    "xml2js": "^0.4.19",
    "zebra-crossing": "^0.1.1"
  },
  "directories": {
    "lib": "lib"
  },
  "devDependencies": {
    "@types/chai": "^4.1.7",
    "@types/mocha": "^5.2.5",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-things": "^0.2.0",
    "coveralls": "^3.0.2",
    "mocha": "^5.2.0",
    "nyc": "^11.9.0",
    "randomstring": "^1.1.5",
    "standard": "^10.0.3",
    "ts-node": "^7.0.1",
    "typescript": "^3.1.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justusjonas74/uic-918-3.git"
  },
  "standard": {
    "env": [
      "mocha"
    ]
  },
  "keywords": [
    "uic-918-3",
    "online-ticket",
    "deutsche-bahn",
    "barcode",
    "aztec"
  ],
  "bugs": {
    "url": "https://github.com/justusjonas74/uic-918-3/issues"
  },
  "homepage": "https://github.com/justusjonas74/uic-918-3#readme",
  "nyc": {
    "include": [
      "lib/**/*.ts"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  }
}
